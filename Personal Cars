-- ==================== SEAT CACHE ====================
local seatCache = {}

local function refreshSeatCache()
    seatCache = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("VehicleSeat") or obj:IsA("Seat") then
            table.insert(seatCache, obj)
        end
    end
end

workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("VehicleSeat") or obj:IsA("Seat") then
        table.insert(seatCache, obj)
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    for i = #seatCache, 1, -1 do
        if seatCache[i] == obj then
            table.remove(seatCache, i)
            break
        end
    end
end)

-- ==================== HELPER FUNCTIONS ====================
local function isProperlySeated()
    local character = player.Character
    if not character then return false end
    local humanoid = character:FindFirstChild("Humanoid")
    return humanoid and humanoid.SeatPart and humanoid.SeatPart.Occupant == humanoid
end

local function getNearestSeat()
    local closestSeat, shortestDistance = nil, math.huge
    local rootPart = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end

    for _, seat in ipairs(seatCache) do
        if seat and seat.Parent and not seat.Occupant then
            local dist = (seat.Position - rootPart.Position).Magnitude
            if dist < shortestDistance and dist <= MAX_DISTANCE then
                shortestDistance = dist
                closestSeat = seat
            end
        end
    end
    return closestSeat
end

local function teleportToSeat(seat)
    if not seat then return end
    local rootPart = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    rootPart.CFrame = seat.CFrame * TELEPORT_OFFSET
    task.wait(0.03)
    local humanoid = player.Character:FindFirstChild("Humanoid")
    if humanoid and not seat.Occupant then
        seat:Sit(humanoid)
    end
end

local function ejectOccupant(seat)
    if seat and seat.Occupant then
        local hum = seat.Occupant
        hum.Jump = true
        task.wait(0.12)
        hum.Jump = false
    end
end

local function checkSeatOwnership(seat)
    if not seat or not seat.Occupant then return end
    local occupantPlayer = Players:GetPlayerFromCharacter(seat.Occupant.Parent)
    if not occupantPlayer then return end

    if not currentOwner and occupantPlayer == player then
        currentOwner = player
        Rayfield:Notify({Title = "Seat Locked", Content = "You are now the owner", Duration = 3})
    end

    if occupantPlayer ~= player and currentOwner == player then
        Rayfield:Notify({Title = "Seat Protected", Content = occupantPlayer.Name .. " ejected", Duration = 2})
        ejectOccupant(seat)
    end
end

local function bringPlayerToFront(target)
    if not target or not target.Character then return end
    local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
    local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not targetRoot or not myRoot then return end
    local frontCFrame = myRoot.CFrame * CFrame.new(0, 0, -6)
    targetRoot.CFrame = frontCFrame
end

local function getRandomPositionAround(center, radius)
    local angle = math.random() * math.pi * 2
    local dist = math.random() * radius
    return center + Vector3.new(math.cos(angle) * dist, math.random(-25, 25), math.sin(angle) * dist)
end

local function resetPosition()
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = CFrame.new(getRandomPositionAround(RESET_CENTER, RANDOM_RADIUS))
    end
end

-- ==================== MAIN LOOP ====================
local function startSeatSpam()
    if seatConnection then return end
    refreshSeatCache()
    isSpamming = true

    seatConnection = RunService.RenderStepped:Connect(function()
        if not isSpamming then return end

        if not isProperlySeated() then
            local nearest = getNearestSeat()
            if nearest then teleportToSeat(nearest) end
            resetPosition()
        else
            local seat = player.Character.Humanoid.SeatPart
            if seat then checkSeatOwnership(seat) end
        end

        if loopBringEnabled then
            for _, target in ipairs(loopBringTargets) do
                bringPlayerToFront(target)
            end
        end
    end)
end

local function stopSeatSpam()
    isSpamming = false
    if seatConnection then seatConnection:Disconnect() seatConnection = nil end
    currentOwner = nil
end

-- ==================== ANTI-FLING + VEHICLE FLY + MULTI TOOL ====================
RunService.Heartbeat:Connect(function()
    local character = player.Character
    if not character then return end
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- Anti-Fling
    if antiFlingEnabled and root.Velocity.Magnitude > 120 then
        root.Velocity = Vector3.new(0, root.Velocity.Y, 0)
        root.RotVelocity = Vector3.new(0, 0, 0)
    end

    -- Vehicle Fly (vfly)
    if vehicleFlyEnabled then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid and humanoid.SeatPart and humanoid.SeatPart:IsA("VehicleSeat") then
            local seat = humanoid.SeatPart
            local moveDir = Vector3.new()

            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += seat.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= seat.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= seat.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += seat.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir -= Vector3.new(0,1,0) end

            seat.AssemblyLinearVelocity = moveDir * vehicleFlySpeed
        end
    end
end)

