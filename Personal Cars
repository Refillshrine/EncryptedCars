-- Seat Cache System (This is what removes most of the lag)
local seatCache = {}

local function refreshSeatCache()
    seatCache = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("VehicleSeat") or obj:IsA("Seat") then
            table.insert(seatCache, obj)
        end
    end
end

-- Keep cache updated live
workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("VehicleSeat") or obj:IsA("Seat") then
        table.insert(seatCache, obj)
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    if obj:IsA("VehicleSeat") or obj:IsA("Seat") then
        for i = #seatCache, 1, -1 do
            if seatCache[i] == obj then
                table.remove(seatCache, i)
                break
            end
        end
    end
end)

-- Numpad Cycle
local autoCycleEnabled = false
local tapsPerSecond = 10
local selectedKeys = {"KeypadOne","KeypadTwo","KeypadThree","KeypadFour","KeypadFive",
                      "KeypadSix","KeypadSeven","KeypadEight","KeypadNine","KeypadZero"}
