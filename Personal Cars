-- ==================== AUTO CLICKER (L Key) ====================
local autoClickerEnabled = false
local clickConnection = nil

local function startAutoClicker()
    if clickConnection then return end
    clickConnection = RunService.Heartbeat:Connect(function()
        if not autoClickerEnabled then return end
        
        local character = player.Character
        if not character then return end
        
        local tool = character:FindFirstChildOfClass("Tool")
        if tool then
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)   -- Down
            task.wait(0.007)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)  -- Up
        end
    end)
end

local function stopAutoClicker()
    if clickConnection then
        clickConnection:Disconnect()
        clickConnection = nil
    end
end

local function toggleAutoClicker()
    autoClickerEnabled = not autoClickerEnabled
    if autoClickerEnabled then
        startAutoClicker()
        Rayfield:Notify({Title = "Auto Clicker", Content = "✅ ENABLED (L)", Duration = 2})
    else
        stopAutoClicker()
        Rayfield:Notify({Title = "Auto Clicker", Content = "❌ DISABLED (L)", Duration = 2})
    end
end

-- L Key Toggle
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.L then
        toggleAutoClicker()
    end
end)

-- ==================== AUTO CAR COUNTER ====================
local RESET_CENTER = Vector3.new(8.582, -12.629, -34.327)
local RANDOM_RADIUS = 500
local MAX_DISTANCE = 3000
local TELEPORT_OFFSET = CFrame.new(0, 2, 0)

local isSpamming = false
local seatConnection = nil
local seatCache = {}

local function refreshSeatCache()
    seatCache = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("VehicleSeat") or obj:IsA("Seat") then
            table.insert(seatCache, obj)
        end
    end
end

workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("VehicleSeat") or obj:IsA("Seat") then
        table.insert(seatCache, obj)
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    for i = #seatCache, 1, -1 do
        if seatCache[i] == obj then
            table.remove(seatCache, i)
            break
        end
    end
end)

local function getNearestSeat()
    local closestSeat = nil
    local shortestDistance = math.huge
    local rootPart = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end

    for _, seat in ipairs(seatCache) do
        if seat and seat.Parent and not seat.Occupant then
            local distance = (seat.Position - rootPart.Position).Magnitude
            if distance < shortestDistance and distance <= MAX_DISTANCE then
                shortestDistance = distance
                closestSeat = seat
            end
        end
    end
    return closestSeat
end

local function teleportToSeat(seat)
    if not seat or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local rootPart = player.Character.HumanoidRootPart
    rootPart.CFrame = seat.CFrame * TELEPORT_OFFSET
    task.wait(0.03)
    local humanoid = player.Character:FindFirstChild("Humanoid")
    if humanoid and seat and not seat.Occupant then
        seat:Sit(humanoid)
    end
end

local function getRandomPositionAround(center, radius)
    local angle = math.random() * math.pi * 2
    local distance = math.random() * radius
    local offsetX = math.cos(angle) * distance
    local offsetZ = math.sin(angle) * distance
    local offsetY = math.random(-25, 25)
    return center + Vector3.new(offsetX, offsetY, offsetZ)
end

local function resetPosition()
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local rootPart = player.Character.HumanoidRootPart
    local randomPos = getRandomPositionAround(RESET_CENTER, RANDOM_RADIUS)
    rootPart.CFrame = CFrame.new(randomPos)
end

local function startSeatSpam()
    if seatConnection then return end
    refreshSeatCache()
    isSpamming = true
    seatConnection = RunService.RenderStepped:Connect(function()
        if not isSpamming then return end
        local nearest = getNearestSeat()
        if nearest then teleportToSeat(nearest) end
        resetPosition()
        task.wait(0.001)
    end)
end

local function stopSeatSpam()
    isSpamming = false
    if seatConnection then
        seatConnection:Disconnect()
        seatConnection = nil
    end
end

-- Death Handler
local function setupCharacter(character)
    local humanoid = character:WaitForChild("Humanoid")
    humanoid.Died:Connect(function()
        task.wait(2)
        if isSpamming then
            local newChar = player.Character or player.CharacterAdded:Wait()
            setupCharacter(newChar)
            stopSeatSpam()
            task.wait(0.5)
            startSeatSpam()
            Rayfield:Notify({Title = "Auto Counter", Content = "Respawned - Restarted", Duration = 3})
        end
    end)
end

if player.Character then setupCharacter(player.Character) end
player.CharacterAdded:Connect(setupCharacter)

