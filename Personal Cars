-- ==================== SEAT CACHE & BASIC HELPERS (unchanged) ====================
local seatCache = {}

local function refreshSeatCache()
    seatCache = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("VehicleSeat") or obj:IsA("Seat") then
            table.insert(seatCache, obj)
        end
    end
end

workspace.DescendantAdded:Connect(refreshSeatCache)
workspace.DescendantRemoving:Connect(function(obj)
    for i = #seatCache, 1, -1 do
        if seatCache[i] == obj then table.remove(seatCache, i) break end
    end
end)

local function isProperlySeated()
    local char = player.Character
    local hum = char and char:FindFirstChild("Humanoid")
    return hum and hum.SeatPart and hum.SeatPart.Occupant == hum
end

local function getNearestSeat()
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local closest, dist = nil, math.huge
    for _, seat in ipairs(seatCache) do
        if seat and seat.Parent and not seat.Occupant then
            local d = (seat.Position - root.Position).Magnitude
            if d < dist and d <= MAX_DISTANCE then
                dist = d
                closest = seat
            end
        end
    end
    return closest
end

local function teleportToSeat(seat)
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root or not seat then return end
    root.CFrame = seat.CFrame * TELEPORT_OFFSET
    task.wait(0.03)
    local hum = player.Character:FindFirstChild("Humanoid")
    if hum and not seat.Occupant then seat:Sit(hum) end
end

local function ejectOccupant(seat)
    if seat and seat.Occupant then
        local hum = seat.Occupant
        hum.Jump = true
        task.wait(0.12)
        hum.Jump = false
    end
end

local function checkSeatOwnership(seat)
    if not seat or not seat.Occupant then return end
    local occupant = Players:GetPlayerFromCharacter(seat.Occupant.Parent)
    if not occupant then return end

    if not currentOwner and occupant == player then
        currentOwner = player
    elseif occupant ~= player and currentOwner == player then
        ejectOccupant(seat)
    end
end

-- ==================== IY-STYLE LOOPBRING + HITBOX ====================
local function bringPlayer(target)
    if not target or not target.Character then return end
    local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
    local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not targetRoot or not myRoot then return end

    -- Better positioning (in front + slightly above ground)
    local frontCFrame = myRoot.CFrame * CFrame.new(0, 2, -5)
    targetRoot.CFrame = frontCFrame
    targetRoot.Velocity = Vector3.new(0, 0, 0)   -- Stop momentum
end

-- Hitbox Expander (IY style - only on selected targets)
local function applyHitbox(target)
    if not target or not target.Character then return end
    local head = target.Character:FindFirstChild("Head")
    if head then
        head.Size = Vector3.new(10, 10, 10)
        head.Transparency = 0.6
        head.CanCollide = false
    end
end

-- Main LoopBring loop (more stable than before)
local bringLoop = nil
local function startLoopBring()
    if bringLoop then return end
    bringLoop = task.spawn(function()
        while loopBringEnabled do
            for _, target in ipairs(loopBringTargets) do
                bringPlayer(target)
                if hitboxExpanderEnabled then
                    applyHitbox(target)
                end
            end
            task.wait(loopBringDelay)
        end
    end)
end

local function stopLoopBring()
    loopBringEnabled = false
    if bringLoop then
        task.cancel(bringLoop)
        bringLoop = nil
    end
end

-- ==================== MAIN AUTO COUNTER LOOP ====================
local function startSeatSpam()
    if seatConnection then return end
    refreshSeatCache()
    isSpamming = true

    seatConnection = RunService.RenderStepped:Connect(function()
        if not isSpamming then return end

        if not isProperlySeated() then
            local nearest = getNearestSeat()
            if nearest then teleportToSeat(nearest) end
            -- resetPosition() if you still want it
        else
            local seat = player.Character.Humanoid.SeatPart
            if seat then checkSeatOwnership(seat) end
        end
    end)
end

local function stopSeatSpam()
    isSpamming = false
    if seatConnection then seatConnection:Disconnect() seatConnection = nil end
    currentOwner = nil
end

-- ==================== ANTI-EXPLOITER FEATURES ====================
RunService.Heartbeat:Connect(function()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if antiFlingEnabled and root.Velocity.Magnitude > 120 then
        root.Velocity = Vector3.new(0, root.Velocity.Y * 0.5, 0)
        root.RotVelocity = Vector3.new(0,0,0)
    end

    if vehicleFlyEnabled then
        local hum = char:FindFirstChild("Humanoid")
        if hum and hum.SeatPart and hum.SeatPart:IsA("VehicleSeat") then
            local seat = hum.SeatPart
            local dir = Vector3.new()
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += seat.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= seat.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= seat.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += seat.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= Vector3.new(0,1,0) end

            seat.AssemblyLinearVelocity = dir * vehicleFlySpeed
        end
    end
end)

