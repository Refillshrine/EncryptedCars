local player = Players.LocalPlayer
local RESET_CENTER = Vector3.new(8.582, -12.629, -34.327)
local RANDOM_RADIUS = 500
local MAX_DISTANCE = 3000
local TELEPORT_OFFSET = CFrame.new(0, 2, 0)

local isSpamming = false
local seatConnection = nil
local currentOwner = nil

-- ==================== SEAT CACHE ====================
local seatCache = {}

local function refreshSeatCache()
    seatCache = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("VehicleSeat") or obj:IsA("Seat") then
            table.insert(seatCache, obj)
        end
    end
end

workspace.DescendantAdded:Connect(refreshSeatCache)
workspace.DescendantRemoving:Connect(function(obj)
    for i = #seatCache, 1, -1 do
        if seatCache[i] == obj then
            table.remove(seatCache, i)
            break
        end
    end
end)

-- ==================== HELPER FUNCTIONS ====================
local function isProperlySeated()
    local character = player.Character
    if not character then return false end
    local humanoid = character:FindFirstChild("Humanoid")
    return humanoid and humanoid.SeatPart and humanoid.SeatPart.Occupant == humanoid
end

local function getNearestSeat()
    local rootPart = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end

    local closestSeat = nil
    local shortestDistance = math.huge

    for _, seat in ipairs(seatCache) do
        if seat and seat.Parent and not seat.Occupant then
            local distance = (seat.Position - rootPart.Position).Magnitude
            if distance < shortestDistance and distance <= MAX_DISTANCE then
                shortestDistance = distance
                closestSeat = seat
            end
        end
    end
    return closestSeat
end

local function teleportToSeat(seat)
    if not seat then return end
    local rootPart = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    rootPart.CFrame = seat.CFrame * TELEPORT_OFFSET
    task.wait(0.03)

    local humanoid = player.Character:FindFirstChild("Humanoid")
    if humanoid and not seat.Occupant then
        seat:Sit(humanoid)
    end
end

local function ejectOccupant(seat)
    if seat and seat.Occupant then
        local hum = seat.Occupant
        hum.Jump = true
        task.wait(0.15)
        hum.Jump = false
    end
end

local function checkSeatOwnership(seat)
    if not seat or not seat.Occupant then return end
    local occupantPlayer = Players:GetPlayerFromCharacter(seat.Occupant.Parent)
    if not occupantPlayer then return end

    if not currentOwner and occupantPlayer == player then
        currentOwner = player
        Rayfield:Notify({Title = "Seat Locked", Content = "You are now the owner", Duration = 3})
    elseif occupantPlayer ~= player and currentOwner == player then
        Rayfield:Notify({Title = "Seat Protected", Content = occupantPlayer.Name .. " was auto-ejected", Duration = 2})
        ejectOccupant(seat)
    end
end

local function getRandomPositionAround(center, radius)
    local angle = math.random() * math.pi * 2
    local distance = math.random() * radius
    return center + Vector3.new(math.cos(angle) * distance, math.random(-25, 25), math.sin(angle) * distance)
end

local function resetPosition()
    local rootPart = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        rootPart.CFrame = CFrame.new(getRandomPositionAround(RESET_CENTER, RANDOM_RADIUS))
    end
end

-- ==================== MAIN AUTO COUNTER + SEAT LOCK (Optimized) ====================
local function startSeatSpam()
    if seatConnection then return end
    refreshSeatCache()
    isSpamming = true

    seatConnection = RunService.Heartbeat:Connect(function()  -- Changed to Heartbeat (lighter than RenderStepped)
        if not isSpamming then return end

        if not isProperlySeated() then
            local nearest = getNearestSeat()
            if nearest then
                teleportToSeat(nearest)
            end
            resetPosition()
        else
            local seat = player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.SeatPart
            if seat then
                checkSeatOwnership(seat)
            end
        end
    end)
end

local function stopSeatSpam()
    isSpamming = false
    if seatConnection then
        seatConnection:Disconnect()
        seatConnection = nil
    end
    currentOwner = nil
end

-- ==================== MANUAL EJECT ====================
player.Chatted:Connect(function(msg)
    if msg:lower() == "/eject" and currentOwner == player then
        local character = player.Character
        if character and character:FindFirstChild("Humanoid") then
            local seat = character.Humanoid.SeatPart
            if seat then
                ejectOccupant(seat)
                Rayfield:Notify({Title = "Eject", Content = "Everyone ejected from your seat", Duration = 3})
            end
        end
    end
end)

