RunService.Heartbeat:Connect(function()
    if not antiRagdollEnabled then return end
    local character = player.Character
    if not character then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end

    if humanoid.PlatformStand or humanoid:GetState() == Enum.HumanoidStateType.Physics then
        unRagdollRemote:FireServer()
        humanoid.PlatformStand = false
    end
end)

-- ==================== DEATH HANDLING ====================
local function setupCharacter(character)
    local humanoid = character:WaitForChild("Humanoid")
    humanoid.Died:Connect(function()
        task.wait(2)
        if isSpamming then
            local newChar = player.Character or player.CharacterAdded:Wait()
            setupCharacter(newChar)
            stopSeatSpam()
            task.wait(0.5)
            startSeatSpam()
            Rayfield:Notify({Title = "Auto Counter", Content = "Respawned - Restarted", Duration = 3})
        end
    end)
end

if player.Character then setupCharacter(player.Character) end
player.CharacterAdded:Connect(setupCharacter)

-- ==================== NUMPAD + AUTO CLICKER (unchanged) ====================
local autoCycleEnabled = false
local tapsPerSecond = 10
local selectedKeys = {"KeypadOne","KeypadTwo","KeypadThree","KeypadFour","KeypadFive",
                      "KeypadSix","KeypadSeven","KeypadEight","KeypadNine","KeypadZero"}
local currentIndex = 1

task.spawn(function()
    while true do
        if autoCycleEnabled then
            local vim = VirtualInputManager
            local keyName = selectedKeys[currentIndex]
            local keyCode = Enum.KeyCode[keyName]
            vim:SendKeyEvent(true, keyCode, false, game)
            task.wait(0.001)
            vim:SendKeyEvent(false, keyCode, false, game)
            currentIndex = (currentIndex % #selectedKeys) + 1
            task.wait(1 / tapsPerSecond)
        else
            task.wait(0.1)
        end
    end
end)

local autoClickerEnabled = false
local clicksPerSecond = 12

task.spawn(function()
    while true do
        if autoClickerEnabled then
            VirtualInputManager:SendMouseButtonEvent(160, 0, 0, true, game, 0)
            task.wait(0.001)
            VirtualInputManager:SendMouseButtonEvent(160, 0, 0, false, game, 0)
            task.wait(1 / clicksPerSecond)
        else
            task.wait(0.1)
        end
    end
end)

