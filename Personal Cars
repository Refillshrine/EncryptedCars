-- ==================== IY-STYLE LOOPBRING + HITBOX ====================
local function bringPlayer(target)
    if not target or not target.Character then return end
    local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
    local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not targetRoot or not myRoot then return end

    -- Better positioning (in front + slightly above ground)
    local frontCFrame = myRoot.CFrame * CFrame.new(0, 2, -5)
    targetRoot.CFrame = frontCFrame
    targetRoot.Velocity = Vector3.new(0, 0, 0)   -- Stop momentum
end

-- Hitbox Expander (IY style - only on selected targets)
local function applyHitbox(target)
    if not target or not target.Character then return end
    local head = target.Character:FindFirstChild("Head")
    if head then
        head.Size = Vector3.new(10, 10, 10)
        head.Transparency = 0.6
        head.CanCollide = false
    end
end

-- Main LoopBring loop (more stable than before)
