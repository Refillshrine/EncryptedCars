local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local RESET_CENTER = Vector3.new(8.582, -12.629, -34.327)
local RANDOM_RADIUS = 500
local MAX_DISTANCE = 3000
local TELEPORT_OFFSET = CFrame.new(0, 2, 0)

local isCounterEnabled = false
local counterConnection = nil
local currentOwner = nil          -- Persistent owner
local lockedSeats = {}            -- Table to track which seats you own

-- ==================== SEAT CACHE ====================
local seatCache = {}

local function refreshSeatCache()
    seatCache = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("VehicleSeat") or obj:IsA("Seat") then
            table.insert(seatCache, obj)
        end
    end
end

refreshSeatCache()
workspace.DescendantAdded:Connect(refreshSeatCache)
workspace.DescendantRemoving:Connect(function(obj)
    for i = #seatCache, 1, -1 do
        if seatCache[i] == obj then table.remove(seatCache, i) break end
    end
end)

-- ==================== AUTO CAR COUNTER ====================
local function isProperlySeated()
    local hum = player.Character and player.Character:FindFirstChild("Humanoid")
    return hum and hum.SeatPart and hum.SeatPart.Occupant == hum
end

local function getNearestSeat()
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local closest, dist = nil, math.huge
    for _, seat in ipairs(seatCache) do
        if seat and seat.Parent and not seat.Occupant then
            local d = (seat.Position - root.Position).Magnitude
            if d < dist and d <= MAX_DISTANCE then
                dist = d
                closest = seat
            end
        end
    end
    return closest
end

local function teleportToSeat(seat)
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root or not seat then return end
    root.CFrame = seat.CFrame * TELEPORT_OFFSET
    task.wait(0.05)
    local hum = player.Character:FindFirstChild("Humanoid")
    if hum and not seat.Occupant then seat:Sit(hum) end
end

local function resetPosition()
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if root then
        local angle = math.random() * math.pi * 2
        local dist = math.random() * RANDOM_RADIUS
        root.CFrame = CFrame.new(RESET_CENTER + Vector3.new(math.cos(angle)*dist, math.random(-25,25), math.sin(angle)*dist))
    end
end

local function startAutoCounter()
    if counterConnection then return end
    isCounterEnabled = true

    counterConnection = RunService.Heartbeat:Connect(function()
        if not isCounterEnabled then return end
        if not isProperlySeated() then
            local nearest = getNearestSeat()
            if nearest then teleportToSeat(nearest) end
            resetPosition()
        end
    end)
end

local function stopAutoCounter()
    isCounterEnabled = false
    if counterConnection then counterConnection:Disconnect() counterConnection = nil end
end

-- ==================== PERSISTENT SEAT LOCK (Best for single-seat cars) ====================
local function ejectOccupant(seat)
    if seat and seat.Occupant then
        local hum = seat.Occupant
        hum.Jump = true
        task.wait(0.15)
        hum.Jump = false
    end
end

local function setupSeatLock()
    currentOwner = nil
    lockedSeats = {}

    -- Main lock logic (runs 4 times per second - very light)
    task.spawn(function()
        while task.wait(0.25) do
            if currentOwner == player then
                for _, seat in ipairs(seatCache) do
                    if seat.Occupant then
                        local plr = Players:GetPlayerFromCharacter(seat.Occupant.Parent)
                        if plr and plr ~= player then
                            ejectOccupant(seat)
                        end
                    end
                end
            end
        end
    end)
end

-- When you sit, claim the seat as yours
local function claimCurrentSeat()
    local hum = player.Character and player.Character:FindFirstChild("Humanoid")
    if hum and hum.SeatPart then
        local seat = hum.SeatPart
        if not table.find(lockedSeats, seat) then
            table.insert(lockedSeats, seat)
            if not currentOwner then
                currentOwner = player
                Rayfield:Notify({Title = "Seat Locked", Content = "This car is now locked to you", Duration = 4})
            end
        end
    end
end

-- Auto claim when you sit
RunService.Heartbeat:Connect(function()
    if isProperlySeated() then
        claimCurrentSeat()
    end
end)

-- Manual eject
player.Chatted:Connect(function(msg)
    if msg:lower() == "/eject" and currentOwner == player then
        for _, seat in ipairs(lockedSeats) do
            ejectOccupant(seat)
        end
        Rayfield:Notify({Title = "Eject", Content = "All locked cars ejected", Duration = 3})
    end
end)

